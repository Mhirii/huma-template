meta {
  name: Signup
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}",
    "username": "{{username}}"
  }
}

script:pre-request {
  bru.setVar("username", bru.interpolate("{{$randomUserName}}"));
  bru.setVar("email", bru.interpolate("{{$randomEmail}}"));
  bru.setVar("password", bru.interpolate("{{randomPassword}}"));
}

tests {
  test("contains tokens", function () {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.access_token).to.not.be.empty;
    expect(body.access_token_expires_at).to.exist;
    expect(body.refresh_token).to.not.be.empty;
    expect(body.refresh_token_expires_at).to.exist;
  });
  
}
